---
import { existsSync } from "node:fs";
import { join } from "node:path";
import { site } from "../config/site";

const logoExists = existsSync(join(process.cwd(), "public", "logo.png"));
---

<header class="site-header">
  <a class="brand" href="/" aria-label={`${site.name} ホーム`}>
    {logoExists ? (
      <img class="brand-logo" src={site.logoPath} alt={site.name} width="180" height="40" />
    ) : (
      <span class="brand-fallback">
        <span class="brand-icon" aria-hidden="true">✓</span>
        <span class="brand-text">{site.name}</span>
      </span>
    )}
  </a>
  <nav class="site-nav" aria-label="主要ナビゲーション">
    <a href="/#tools">無料ツール</a>
    <a href="/waitlist/">先行案内</a>
    <a href="/terms/">利用規約</a>
  </nav>
</header>
