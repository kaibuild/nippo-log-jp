---
import { site } from "../config/site";
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
  canonicalPath?: string;
};

const { title, description = site.description, canonicalPath = "/" } = Astro.props;
const pageTitle = title ? `${title} | ${site.name}` : `${site.name} | 作業日報の無料ツール`;
const canonicalUrl = new URL(canonicalPath, site.productionUrl).toString();
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content={site.themeColor} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href={site.faviconPath} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="日報ログ ホーム">
        <span class="brand-icon" aria-hidden="true">✓</span>
        <span class="brand-text">{site.name}</span>
      </a>
      <nav class="site-nav" aria-label="主要ナビゲーション">
        <a href="/#tools">無料ツール</a>
        <a href="/waitlist">先行案内</a>
        <a href="/terms">利用規約</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <strong>{site.name}</strong>
        <p>作業日報のフォーマット作成と記録整理を支援する無料ツール集です。</p>
      </div>
      <nav aria-label="フッターナビゲーション">
        <a href="/privacy">プライバシーポリシー</a>
        <a href="/terms">利用規約</a>
        <a href="/sitemap.xml">sitemap.xml</a>
      </nav>
    </footer>
  </body>
</html>
